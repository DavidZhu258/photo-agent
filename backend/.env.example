APP_ENV=local
DATABASE_URL=mysql+pymysql://photo_agent:photo_agent@127.0.0.1:3306/photo_agent?charset=utf8mb4
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_VISION_MODEL=qwen3-vl:4b-instruct
VLM_PROVIDER=heuristic
DEEPINFRA_API_KEY=
DEEPINFRA_BASE_URL=https://api.deepinfra.com/v1/openai
DEEPINFRA_VISION_MODEL=google/gemini-3.1-pro
DEEPINFRA_NARRATIVE_MODEL=google/gemini-3.1-pro
TRAVEL_MAIN_API_KEY=
TRAVEL_MAIN_BASE_URL=https://zzshu.cc/v1
TRAVEL_ORCHESTRATION_MODE=orchestrator
TRAVEL_MODEL_ORCHESTRATOR=gpt-5.5
TRAVEL_MODEL_COMPLEX_ROUTE=openai/gpt-oss-120b
TRAVEL_MODEL_REASONING=openai/gpt-oss-120b
TRAVEL_MODEL_REASONING_EFFORT=high
TRAVEL_MODEL_FAST=deepseek-ai/DeepSeek-V4-Flash
TRAVEL_ORCHESTRATOR_MAX_TOOL_ROUNDS=6
TRAVEL_COMPLEX_MAX_TOOL_ROUNDS=10
# Default production token surface is Serper.dev + DeepInfra.
# LiteLLM remains a legacy/local compatibility path and is ignored unless TRAVEL_ALLOW_LITELLM_FALLBACK=true.
LITELLM_BASE_URL=
LITELLM_API_KEY=
# Optional Gemini visual-first provider. If unset, the backend can still use DeepInfra or heuristic fallback.
VISUAL_PRIMARY_PROVIDER=
GOOGLE_API_KEY=
GOOGLE_GENAI_USE_VERTEXAI=false
GOOGLE_CLOUD_PROJECT=
GOOGLE_CLOUD_LOCATION=global
GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta
GEMINI_VISION_MODEL=gemini-3.1-pro-preview
GEMINI_THINKING_LEVEL=HIGH
GEMINI_MEDIA_RESOLUTION=HIGH
REDIS_URL=redis://127.0.0.1:6379/0
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com
SERPER_API_KEY=
SERPER_BASE_URL=https://google.serper.dev
TRAVEL_GOOGLE_SERVICES_PROVIDER=serper
TRAVEL_ALLOW_DIRECT_GOOGLE_PLACES=false
TRAVEL_ALLOW_SERPAPI_FALLBACK=false
TRAVEL_ALLOW_LITELLM_FALLBACK=false
# Legacy compatibility only; ignored by default for travel.
GOOGLE_MAPS_API_KEY=
SERPAPI_API_KEY=
PUBLIC_IMAGE_BASE_URL=
EXTERNAL_API_TIMEOUT_SECONDS=60
TRAVEL_DECISION_TIMEOUT_SECONDS=20
EXA_API_KEY=
EXA_BASE_URL=https://api.exa.ai
EXA_TIMEOUT_SECONDS=8
TABIJI_ENABLED=true
TABIJI_BASE_URL=https://tabiji.ai/api/v1
TABIJI_TIMEOUT_SECONDS=6
OSRM_BASE_URL=
OSRM_TIMEOUT_SECONDS=1.5
ADMIN_TOKEN=photo-agent-local-admin
